@"
# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfstate.backup
crash.log
crash.*.log

# tfvars often contain secrets/environment-specific values - exclude by default
*.tfvars
*.tfvars.json
!envs/**/example.tfvars

# CLI config
.terraformrc
terraform.rc

# Provider credentials / secrets
*.pem
*.key
.env

# JetBrains IDE
.idea/

# OS / editor junk
.DS_Store
Thumbs.db
.vscode/
"@ | Out-File -Encoding utf8 .gitignore